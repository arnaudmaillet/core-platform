# k8s/overlays/staging/auth.env — auth-server (staging). Managed ElastiCache +
# CNPG. Secret creds via 'backend-creds' (REDIS_PASSWORD); DATABASE_URL from the
# CNPG staging-auth-postgres-app secret (see patch-auth-db.yaml). The ES256
# SIGNING PEMs + Keycloak client secret are sensitive -> injected from the
# 'auth-secrets' ExternalSecret (see external-secrets.yaml), NOT this ConfigMap.

# ── PostgreSQL session/issuance store (CNPG; DATABASE_URL via patch) ───────────
PG_TOPOLOGY=single

# ── Redis (managed ElastiCache, cluster mode + TLS) ───────────────────────────
REDIS_HOSTS=<<ELASTICACHE_CONFIG_ENDPOINT>>:6379
REDIS_TOPOLOGY=cluster

# ── Token issuance (ES256 edge tokens) ────────────────────────────────────────
AUTH_TOKEN_ISSUER=https://auth.core-platform.click
AUTH_TOKEN_AUDIENCE=core-platform
AUTH_SIGNING_KID=staging-es256-1
AUTH_ACCESS_TTL_SECS=900
AUTH_REFRESH_TTL_SECS=2592000
AUTH_SESSION_TTL_SECS=2592000
AUTH_ABSOLUTE_TTL_SECS=7776000

# ── Downstream + federated IdP (Keycloak). Client secret via auth-secrets. ─────
AUTH_ACCOUNT_GRPC_ENDPOINT=http://staging-account-server:50059
AUTH_KEYCLOAK_TOKEN_ENDPOINT=<<KEYCLOAK_TOKEN_ENDPOINT>>
AUTH_KEYCLOAK_CLIENT_ID=core-platform-auth
AUTH_KEYCLOAK_SCOPE=openid

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
