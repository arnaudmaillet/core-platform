# k8s/overlays/staging/search.env — search-server (staging). Managed MSK +
# managed OpenSearch. The OpenSearch master user/password are sensitive ->
# injected from the 'search-creds' ExternalSecret (SEARCH_OPENSEARCH_USER /
# SEARCH_OPENSEARCH_PASSWORD), NOT this ConfigMap. <<…>> filled at deploy.

# ── OpenSearch (managed domain; creds via search-creds) ───────────────────────
SEARCH_OPENSEARCH_URL=https://${OPENSEARCH_ENDPOINT}
SEARCH_INDEX_PREFIX=staging

# ── Kafka ingestion (post[hydrated] + moderation consumers, SASL/SCRAM) ───────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── Hydration sources (post lookup; profile pending its Kafka stream) ─────────
SEARCH_POST_GRPC_ENDPOINT=http://staging-post-server:50056
SEARCH_PROFILE_GRPC_ENDPOINT=http://staging-profile-server:50052

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
