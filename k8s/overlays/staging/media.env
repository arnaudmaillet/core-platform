# k8s/overlays/staging/media.env — media-server (staging). Managed MSK/ElastiCache
# + CNPG + S3. DATABASE_URL via the CNPG staging-media-postgres-app secret (patch).
#
# NB credentials: the S3 client is rusty-s3 with STATIC keys (MEDIA_S3_ACCESS_KEY/
# MEDIA_S3_SECRET_KEY), injected from the 'media-s3-creds' ExternalSecret — it does
# NOT use the IRSA role on the SA (see Block 4/5 notes). Bucket/region/endpoint are
# non-secret config and live here.

# ── PostgreSQL asset-lifecycle SoR (CNPG; DATABASE_URL via patch) ─────────────
PG_TOPOLOGY=single

# ── Redis hot cache (managed ElastiCache) ─────────────────────────────────────
REDIS_HOSTS=${ELASTICACHE_CONFIG_ENDPOINT}:6379
REDIS_TOPOLOGY=cluster

# ── Kafka transform pipeline (managed MSK, SASL/SCRAM over TLS) ───────────────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── S3 object store (real AWS S3 via rusty-s3 SigV4; keys via media-s3-creds) ──
MEDIA_OBJECT_STORE_BUCKET=core-platform-staging-media-724772065879
MEDIA_OBJECT_STORE_ENDPOINT=https://s3.us-east-1.amazonaws.com
MEDIA_OBJECT_STORE_REGION=us-east-1

# ── Delivery + screening ──────────────────────────────────────────────────────
# CloudFront not yet provisioned -> resolve via the bucket regional domain for now.
MEDIA_CDN_BASE_URL=https://core-platform-staging-media-724772065879.s3.us-east-1.amazonaws.com
MEDIA_SCREEN_GRPC_ENDPOINT=http://staging-moderation-server:50061
MEDIA_DEDUP_ENABLED=false

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
