# k8s/overlays/staging/counter.env — counter-server + counter-worker (staging).
# Managed MSK/ElastiCache + in-cluster Scylla (operator) / CNPG. Secret creds
# (KAFKA_SASL_*/REDIS_PASSWORD) come from 'backend-creds'; DATABASE_URL from the
# CNPG staging-counter-postgres-app secret (see patch-counter-*-db.yaml). <<…>>
# endpoints are filled at deploy from the Terraform data-store outputs.

# ── PostgreSQL warm ledger (CNPG; DATABASE_URL injected via patch) ─────────────
PG_TOPOLOGY=single

# ── ScyllaDB cold time-series (in-cluster ScyllaCluster) ──────────────────────
SCYLLA_CONTACT_POINTS=scylla-client.scylla.svc.cluster.local:9042
SCYLLA_LOCAL_DC=datacenter1
SCYLLA_KEYSPACE=counter

# ── Redis hot tier (managed ElastiCache, cluster mode + TLS) ──────────────────
REDIS_HOSTS=${ELASTICACHE_CONFIG_ENDPOINT}:6379
REDIS_TOPOLOGY=cluster

# ── Kafka firehose ingest (managed MSK, SASL/SCRAM over TLS) ──────────────────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── Reconciliation source (social-graph follower/following counts) ────────────
COUNTER_SOCIAL_GRAPH_GRPC_ENDPOINT=http://staging-social-graph-server:50053

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
