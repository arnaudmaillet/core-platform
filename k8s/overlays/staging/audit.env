# k8s/overlays/staging/audit.env — audit-server + audit-worker (staging). Managed
# MSK + CNPG + S3 Object-Lock (WORM). DATABASE_URL via the CNPG
# staging-audit-postgres-app secret (patch).
#
# ⚠ CRYPTO/CUSTODY (see Block 5 notes): the object-store / witness / KMS clients
# are rusty-s3 with STATIC keys, and the key vault is the v1 ENV-KEK path (real
# AWS KMS + RFC3161/cross-acct WORM witness are the documented external deferral).
# All sensitive material — *_ACCESS_KEY/*_SECRET_KEY, AUDIT_KEK_BASE64,
# AUDIT_CHECKPOINT_SIGNING_KEY_BASE64 — comes from the 'audit-crypto' ExternalSecret,
# NOT this ConfigMap. Non-secret config (buckets/region/endpoints/intervals) here.

# ── PostgreSQL hash-chained ledger (CNPG; DATABASE_URL via patch) ─────────────
PG_TOPOLOGY=single

# ── Kafka ingest (account/auth/moderation.v1.events + audit.v1.events) ────────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── Object-Lock WORM archive (real AWS S3 via rusty-s3; keys via audit-crypto) ─
AUDIT_OBJECT_STORE_BUCKET=core-platform-staging-audit-worm-724772065879
AUDIT_OBJECT_STORE_ENDPOINT=https://s3.us-east-1.amazonaws.com
AUDIT_OBJECT_STORE_REGION=us-east-1

# ── External-witness anchor. Staging points at the same WORM bucket; a true
#    cross-account witness is the external deferral. ───────────────────────────
AUDIT_WITNESS_BUCKET=core-platform-staging-audit-worm-724772065879
AUDIT_WITNESS_ENDPOINT=https://s3.us-east-1.amazonaws.com
AUDIT_WITNESS_REGION=us-east-1

# ── Caller gate on the audit.v1 surface (PR #546) ─────────────────────────────
# REQUIRED in every env: without AUDIT_JWKS_URL the gate is DenyAll (fail-closed)
# — Query/Export/VerifyIntegrity AND RecordPrivileged reject every call. Verify
# against auth's ES256 JWKS; issuer/audience must match what auth mints (auth.env),
# same trio realtime uses (REALTIME_JWKS_URL/_ISSUER/_AUDIENCE).
# NB: callers are authenticated but still need audit:* permissions in the token —
# auth minting those is a tracked follow-up.
AUDIT_JWKS_URL=${AUTH_JWKS_URL}
AUDIT_TOKEN_ISSUER=https://auth.core-platform.click
AUDIT_TOKEN_AUDIENCE=core-platform

# ── Periodic chain loops ──────────────────────────────────────────────────────
AUDIT_CHECKPOINT_INTERVAL_S=300

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
