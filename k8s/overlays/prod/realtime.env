# k8s/overlays/prod/realtime.env — realtime-gateway + realtime-dispatcher
# (prod). Managed MSK/ElastiCache. Secret creds via 'backend-creds'. realtime
# is a System-of-Connection (no SoR datastore): Redis is the presence/registry +
# node-hop pub/sub, Kafka feeds the dispatcher fan-out. <<…>> filled at deploy.

# ── Redis (registry + presence + node Pub/Sub; managed ElastiCache) ───────────
REDIS_HOSTS=${ELASTICACHE_CONFIG_ENDPOINT}:6379
REDIS_TOPOLOGY=cluster

# ── Kafka (dispatcher fan-out consumer, SASL/SCRAM over TLS) ──────────────────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── Edge token verification (ES256, JWKS from auth) ───────────────────────────
REALTIME_JWKS_URL=${AUTH_JWKS_URL}
REALTIME_TOKEN_ISSUER=https://auth.core-platform.click
REALTIME_TOKEN_AUDIENCE=core-platform

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
