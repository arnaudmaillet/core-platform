# k8s/overlays/prod/moderation.env — moderation-server (prod). Managed
# MSK/ElastiCache + in-cluster Scylla (operator) / CNPG. Secret creds via
# 'backend-creds'; DATABASE_URL from the CNPG prod-moderation-postgres-app
# secret (see patch-moderation-db.yaml).

# ── PostgreSQL decision/enforcement SoR (CNPG; DATABASE_URL via patch) ─────────
PG_TOPOLOGY=single

# ── ScyllaDB append-only history feed (in-cluster ScyllaCluster) ──────────────
SCYLLA_CONTACT_POINTS=scylla-client.scylla.svc.cluster.local:9042
SCYLLA_LOCAL_DC=datacenter1
SCYLLA_KEYSPACE=moderation

# ── Redis hot-read enforcement cache (managed ElastiCache) ────────────────────
REDIS_HOSTS=${ELASTICACHE_CONFIG_ENDPOINT}:6379
REDIS_TOPOLOGY=cluster
# ElastiCache enforces transit encryption; without TLS every command times out.
REDIS_TLS=true

# ── Kafka (managed MSK, SASL/SCRAM over TLS) ──────────────────────────────────
KAFKA_BROKERS=${MSK_BOOTSTRAP_BROKERS_SASL_SCRAM}
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# ── Downstream dependency (account enforcement application) ────────────────────
MODERATION_ACCOUNT_GRPC_ENDPOINT=http://prod-account-server:50059

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
